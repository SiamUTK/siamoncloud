{
  "name": "siam-on-cloud",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "build:app": "vite build",
    "start": "node server/index.js",
    "start:node": "node server/index.js",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:src": "eslint \"src/**/*.{js,ts,tsx}\"",
    "enforce:tsx": "node scripts/enforce-src-tsx.mjs",
    "lint:strict": "npm run enforce:tsx",
    "check:ci": "npm run enforce:tsx && npm run lint:src && npm run build",
    "notify": "node scripts/notify.cjs",
    "git:advisor": "node scripts/git-advisor.cjs",
    "build:notify": "npm run build && npm run notify",
    "cleanup:dry": "ts-node scripts/cleanup-unused.ts --dry",
    "cleanup:run": "ts-node scripts/cleanup-unused.ts --run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "lucide-react": "^0.575.0",
    "openai": "^4.28.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "rollup-plugin-visualizer": "^7.0.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vite": "^6.0.5"
  }
}
